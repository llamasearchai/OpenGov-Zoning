# OpenGov Zoning API - Environment Configuration
# Copy this file to .env and update with your actual values

# Application Settings
APP_NAME="OpenGov Zoning API"
APP_VERSION="1.0.0"
APP_ENV="development"
DEBUG=True
SECRET_KEY="your-secret-key-change-in-production"
API_V1_PREFIX="/api/v1"

# Server Configuration
HOST="0.0.0.0"
PORT=8000
WORKERS=1
RELOAD=True

# Database Configuration
DATABASE_URL="sqlite+aiosqlite:///./opengov_zoning.db"
# For PostgreSQL in production:
# DATABASE_URL="postgresql+asyncpg://user:password@localhost/opengov_zoning"

# Database Pool Settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Redis Configuration (for caching and sessions)
REDIS_URL="redis://localhost:6379/0"
REDIS_CACHE_TTL=3600

# Authentication & Security
JWT_SECRET_KEY="your-jwt-secret-key-change-in-production"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# OAuth2 Configuration
OAUTH2_SECRET_KEY="your-oauth2-secret-key"
OAUTH2_TOKEN_URL="https://example.com/token"
OAUTH2_AUTHORIZATION_URL="https://example.com/auth"

# API Keys
OPENAI_API_KEY="your-openai-api-key"
OLLAMA_BASE_URL="http://localhost:11434"

# GIS Configuration
GIS_API_BASE="https://gis.company.com/api"
GIS_API_KEY="your-gis-api-key"

# Email Configuration (for notifications)
SMTP_SERVER="smtp.gmail.com"
SMTP_PORT=587
SMTP_USERNAME="your-email@example.com"
SMTP_PASSWORD="your-app-password"
EMAIL_FROM="noreply@opengovzoning.com"

# File Upload Configuration
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR="./uploads"
SUPPORTED_FORMATS="pdf,docx,txt,html,xml"

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Logging Configuration
LOG_LEVEL="INFO"
LOG_FORMAT="json"
LOG_FILE="./logs/opengov_zoning.log"

# Monitoring & Observability
SENTRY_DSN=""
PROMETHEUS_ENABLED=True
OTEL_ENABLED=False
OTEL_SERVICE_NAME="opengov-zoning-api"

# CORS Settings (restrictive by default for security)
CORS_ORIGINS="http://localhost:3000,http://localhost:8080"
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS="GET,POST,PUT,DELETE,OPTIONS"
CORS_ALLOW_HEADERS="Content-Type,Authorization,X-Requested-With"

# Security Headers
CSP_DEFAULT_SRC="'self'"
CSP_SCRIPT_SRC="'self' 'unsafe-inline'"
CSP_STYLE_SRC="'self' 'unsafe-inline'"

# Feature Flags
ENABLE_REGISTRATION=True
ENABLE_FILE_UPLOAD=True
ENABLE_GIS_INTEGRATION=True
ENABLE_EMAIL_NOTIFICATIONS=True

# Performance Settings
MAX_CONCURRENT_ANALYSES=5
CONFIDENCE_THRESHOLD=0.85
MAX_DOCUMENT_SIZE_MB=50

# Cache Settings
CACHE_TYPE="redis"
CACHE_REDIS_HOST="localhost"
CACHE_REDIS_PORT=6379
CACHE_REDIS_DB=0
CACHE_DEFAULT_TIMEOUT=300

# Session Configuration
SESSION_TYPE="redis"
SESSION_REDIS_HOST="localhost"
SESSION_REDIS_PORT=6379
SESSION_REDIS_DB=1
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE="Lax"

# Testing Configuration
TEST_DATABASE_URL="sqlite+aiosqlite:///./test.db"
TEST_REDIS_URL="redis://localhost:6379/1"

# Documentation
DOCS_URL="/docs"
REDOC_URL="/redoc"
OPENAPI_URL="/openapi.json"